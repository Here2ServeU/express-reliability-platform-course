        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "100 * sum by (job) (rate(http_requests_total{job=~\"$job\",status=~\"5..\"}[$__rate_interval])) / clamp_min(sum by (job) (rate(http_requests_total{job=~\"$job\"}[$__rate_interval])), 0.001)",
